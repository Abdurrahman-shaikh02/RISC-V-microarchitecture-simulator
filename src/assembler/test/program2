start:
    addi r1, r0, 10
    addi r2, r0, 20
    add r3, r1, r2

    sw r3, 0(r0)
    lw r4, 0(r0)

    beq r3, r4, equal
    addi r5, r0, 1
    jal r0, end

equal:
    addi r5, r0, 2

loop:
    addi r1, r1, -1
    bne r1, r0, loop

    jal r6, func
    addi r7, r0, 7
    jal r0, end

func:
    addi r6, r6, 4
    jalr r0, r6, 0

end:
    addi r0, r0, 0
